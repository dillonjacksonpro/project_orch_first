# run.cfg.example — copy to run.cfg and adjust values before use.
# Submit from the repo root: sbatch run.sh run.cfg
#
# SLURM resources (ntasks, cpus-per-task, partition, time) are set via
# #SBATCH directives in run.sh; override them on the sbatch command line:
#   sbatch --ntasks=4 --cpus-per-task=8 --partition=compute run.sh run.cfg

# Path to the directory of input files (required).
# Relative paths are resolved from the current working directory.
DATA_DIR=tests/e2e/data

# Base directory for run output (optional, default: runs/).
# Each invocation creates a timestamped subdirectory:
#   runs/20260407_143022/
#     config.cfg    -- copy of this file
#     stdout.txt    -- orchestrator output (on_output results)
#     stderr.txt    -- orchestrator lifecycle logs
#     exit_code.txt -- numeric exit code of srun
OUTPUT_ROOT=runs
